# External PostgreSQL Connection
EXT_PG_HOST=your_postgres_host
EXT_PG_PORT=5432
EXT_PG_DB=your_database_name
EXT_PG_USER=your_postgres_user
EXT_PG_PASSWORD=your_postgres_password
EXT_PG_SSLMODE=prefer

# Airflow Image
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.3
AIRFLOW_UID=50000

# Airflow Admin
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
